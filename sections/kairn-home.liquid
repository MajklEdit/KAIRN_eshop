{% liquid
  assign collection_link = section.settings.collection_link | default: routes.all_products_collection_url
  assign hero_heading_font = section.settings.hero_heading_font
  if hero_heading_font == blank
    assign hero_heading_font = settings.type_heading_font
  endif
%}

<style>
  {{ hero_heading_font | font_face: font_display: 'swap' }}

  #header-group,
  .shopify-section-group-header-group {
    display: none !important;
  }

  .kairn-home {
    --kairn-black: #050505;
    --kairn-ink: #f5f3ee;
    --kairn-muted: rgba(245, 243, 238, 0.68);
    --kairn-line: rgba(245, 243, 238, 0.16);
    --kairn-paper: #f3f1eb;
    --kairn-paper-ink: #111;
    --kairn-max: 1240px;
    --kairn-nav-height: 84px;
    --kairn-display: {{ hero_heading_font.family }}, {{ hero_heading_font.fallback_families }};
    --kairn-display-weight: {{ hero_heading_font.weight }};
    background: var(--kairn-black);
    color: var(--kairn-ink);
    font-family: var(--font-body--family), Arial, sans-serif;
    letter-spacing: 0;
  }

  .kairn-home a {
    color: inherit;
    text-decoration: none;
  }

  .kairn-shell {
    width: min(100% - 48px, var(--kairn-max));
    margin-inline: auto;
  }

  .kairn-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    box-sizing: border-box;
    display: grid;
    grid-template-columns: minmax(150px, 1fr) auto minmax(150px, 1fr);
    align-items: center;
    gap: clamp(22px, 4vw, 64px);
    padding: 24px clamp(22px, 3vw, 48px);
    background: transparent;
    border-bottom: 1px solid transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    transition:
      padding 220ms ease,
      background-color 220ms ease,
      border-color 220ms ease,
      box-shadow 220ms ease,
      backdrop-filter 220ms ease;
  }

  .kairn-nav.is-scrolled,
  .kairn-nav.is-menu-open {
    padding-block: 16px;
    background: rgba(5, 5, 5, 0.72);
    border-bottom-color: rgba(245, 243, 238, 0.12);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(18px) saturate(150%);
    -webkit-backdrop-filter: blur(18px) saturate(150%);
  }

  .kairn-hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    padding: 0;
    border: none;
    background: none;
    color: inherit;
    cursor: pointer;
  }

  .kairn-hamburger svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .kairn-hamburger [data-icon-close] {
    display: none;
  }

  .kairn-nav.is-menu-open .kairn-hamburger [data-icon-open] {
    display: none;
  }

  .kairn-nav.is-menu-open .kairn-hamburger [data-icon-close] {
    display: block;
  }

  .kairn-logo {
    justify-self: start;
    display: inline-flex;
    align-items: center;
    width: clamp(130px, 16vw, 205px);
    line-height: 0;
  }

  .kairn-logo img {
    display: block;
    width: 100%;
    height: auto;
  }

  .kairn-menu {
    justify-self: center;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(28px, 5vw, 76px);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .kairn-actions {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 20px;
    color: rgba(245, 243, 238, 0.86);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .kairn-currency {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    letter-spacing: 0.08em;
  }

  .kairn-caret {
    width: 12px;
    height: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0.76;
  }

  .kairn-caret svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .kairn-icon {
    position: relative;
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: currentColor;
  }

  .kairn-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .kairn-cart-bubble {
    position: absolute;
    top: -9px;
    right: -10px;
    width: 18px;
    height: 18px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--kairn-ink);
    color: #080808;
    font-size: 0.66rem;
    font-weight: 900;
    line-height: 1;
  }

  .kairn-hero {
    position: relative;
    min-height: clamp(680px, 100svh, 880px);
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
    background: #090909;
  }

  .kairn-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      radial-gradient(circle at 83% 34%, rgba(255,255,255,0.045), transparent 28%),
      linear-gradient(105deg, #080808 0%, #101010 62%, #0b0b0b 100%);
  }

  .kairn-hero::after {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(56vw, 880px);
    z-index: -1;
    background:
      linear-gradient(90deg, rgba(8,8,8,0.76), rgba(8,8,8,0.08) 48%, rgba(8,8,8,0.24)),
      linear-gradient(135deg, #111, #0a0a0a 68%, #111);
  }

  .kairn-hero-copy {
    max-width: 520px;
    padding: clamp(104px, 13vw, 148px) 0 72px;
  }

  .kairn-eyebrow,
  .kairn-section-kicker {
    display: block;
    margin-bottom: 22px;
    color: rgba(245, 243, 238, 0.62);
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .kairn-title {
    margin: 0;
    font-family: var(--kairn-display);
    font-size: clamp(4.5rem, 8vw, 7.5rem);
    font-weight: var(--kairn-display-weight);
    line-height: 0.9;
    letter-spacing: 0.035em;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .kairn-section-title {
    margin: 0;
    font-family: var(--font-heading--family), Impact, sans-serif;
    font-size: clamp(3.8rem, 8vw, 6.7rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: 0.045em;
    text-transform: uppercase;
  }

  .kairn-hero-text {
    max-width: 405px;
    margin: 30px 0 40px;
    color: rgba(245, 243, 238, 0.67);
    font-size: 1rem;
    line-height: 1.56;
    font-weight: 600;
  }

  .kairn-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    min-height: 54px;
    min-width: 204px;
    padding: 0 30px;
    border: 1px solid transparent;
    border-radius: 0;
    background: var(--kairn-paper);
    color: var(--kairn-paper-ink);
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  /* The generic link rule above has higher specificity than .kairn-button.
     Set the CTA colors explicitly so links never inherit the white hero text. */
  .kairn-home a.kairn-button {
    color: var(--kairn-paper-ink);
  }

  .kairn-button:hover {
    transform: translateY(-2px);
    background: #fff;
  }

  .kairn-button:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 4px;
  }

  .kairn-button--dark {
    background: #000;
    color: #fff;
  }

  .kairn-home a.kairn-button--dark {
    color: #fff;
  }

  .kairn-button--dark:hover {
    background: #161616;
  }

  .kairn-benefits {
    background: rgba(10, 10, 10, 0.98);
    border-top: 1px solid rgba(255,255,255,0.08);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .kairn-benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
    padding-block: 34px;
  }

  .kairn-benefit {
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 16px;
    align-items: start;
  }

  .kairn-benefit svg {
    width: 34px;
    height: 34px;
    stroke-width: 1.5;
    opacity: 0.86;
  }

  .kairn-benefit strong {
    display: block;
    margin-bottom: 8px;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .kairn-benefit span {
    color: var(--kairn-muted);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  .kairn-products {
    background: var(--kairn-paper);
    color: var(--kairn-paper-ink);
    padding: 64px 0 70px;
  }

  .kairn-centered {
    text-align: center;
  }

  .kairn-products .kairn-section-kicker {
    color: rgba(17, 17, 17, 0.48);
    margin-bottom: 14px;
  }

  .kairn-products .kairn-section-title {
    font-size: clamp(2.4rem, 4.6vw, 4.1rem);
  }

  .kairn-rule {
    width: 58px;
    height: 2px;
    margin: 26px auto 42px;
    background: #111;
  }

  .kairn-product-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 28px;
  }

  .kairn-product-card {
    background: #fff;
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  .kairn-product-media,
  .kairn-bundle-media,
  .kairn-about-media {
    background:
      radial-gradient(circle at 60% 35%, rgba(255,255,255,0.12), transparent 24%),
      linear-gradient(135deg, #020202, #151515 48%, #050505);
  }

  .kairn-product-media {
    aspect-ratio: 1 / 0.86;
  }

  .kairn-product-body {
    padding: 32px 28px 30px;
    text-align: center;
  }

  .kairn-product-num {
    display: block;
    margin-bottom: 20px;
    color: rgba(17,17,17,0.55);
    font-size: 0.8rem;
    font-weight: 900;
  }

  .kairn-product-title {
    margin: 0 0 14px;
    font-family: var(--font-heading--family), Impact, sans-serif;
    font-size: 1.5rem;
    line-height: 1.05;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .kairn-product-desc {
    margin: 0 auto 22px;
    max-width: 310px;
    color: rgba(17,17,17,0.68);
    font-size: 0.94rem;
    line-height: 1.45;
    font-weight: 600;
  }

  .kairn-price {
    display: block;
    margin-bottom: 24px;
    font-size: 1.45rem;
    font-weight: 900;
  }

  .kairn-bundle {
    margin-top: 38px;
    display: grid;
    grid-template-columns: minmax(180px, 320px) 1fr auto;
    gap: 34px;
    align-items: center;
    background: #e8e6df;
    padding: 32px 42px;
  }

  .kairn-bundle-media {
    aspect-ratio: 1.8 / 1;
    background-color: #111;
  }

  .kairn-bundle-copy span {
    display: block;
    margin-bottom: 10px;
    color: rgba(17,17,17,0.55);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .kairn-bundle-copy h3 {
    margin: 0 0 10px;
    font-family: var(--font-heading--family), Impact, sans-serif;
    font-size: clamp(2rem, 4vw, 3.1rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .kairn-bundle-copy p {
    margin: 0 0 20px;
    color: rgba(17,17,17,0.68);
    font-weight: 600;
  }

  .kairn-materials {
    min-height: 680px;
    display: grid;
    align-items: center;
    background:
      linear-gradient(90deg, rgba(0,0,0,0.94), rgba(0,0,0,0.72) 42%, rgba(0,0,0,0.18)),
      linear-gradient(135deg, #050505, #171717 45%, #050505);
    color: var(--kairn-ink);
    padding: 76px 0;
  }

  .kairn-materials-copy {
    max-width: 480px;
  }

  .kairn-materials .kairn-section-title {
    font-size: clamp(2.7rem, 5vw, 4.6rem);
  }

  .kairn-materials p {
    color: var(--kairn-muted);
    line-height: 1.58;
    font-weight: 600;
  }

  .kairn-material-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 26px;
    margin-top: 44px;
  }

  .kairn-about {
    background: #080808;
    color: var(--kairn-ink);
    padding: 0 0 72px;
  }

  .kairn-about-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 70px;
    align-items: center;
  }

  .kairn-about-media {
    min-height: 420px;
  }

  .kairn-about h2 {
    margin: 0 0 24px;
    font-family: var(--font-heading--family), Impact, sans-serif;
    font-size: clamp(2.6rem, 5vw, 4.8rem);
    line-height: 1;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .kairn-about p {
    max-width: 400px;
    color: var(--kairn-muted);
    line-height: 1.55;
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .kairn-shell {
      width: min(100% - 32px, var(--kairn-max));
    }

    .kairn-nav {
      grid-template-columns: 1fr auto;
      grid-template-areas: "logo actions";
      padding: 18px;
    }

    .kairn-nav.is-scrolled,
    .kairn-nav.is-menu-open {
      padding-block: 14px;
    }

    .kairn-logo {
      grid-area: logo;
    }

    .kairn-hamburger {
      display: inline-flex;
      order: -1;
    }

    .kairn-menu {
      display: none;
      position: absolute;
      grid-column: 1 / -1;
      justify-self: stretch;
      top: 100%;
      left: 0;
      right: 0;
      width: auto;
      flex-direction: column;
      align-items: stretch;
      justify-content: flex-start;
      gap: 0;
      padding: 6px 18px calc(24px + env(safe-area-inset-bottom));
      background: rgba(5, 5, 5, 0.97);
      border-top: 1px solid rgba(245, 243, 238, 0.12);
      backdrop-filter: blur(18px) saturate(150%);
      -webkit-backdrop-filter: blur(18px) saturate(150%);
      max-height: calc(100vh - 100%);
      overflow-y: auto;
    }

    .kairn-nav.is-menu-open .kairn-menu {
      display: flex;
    }

    .kairn-menu a {
      width: 100%;
      padding: 16px 0;
      border-bottom: 1px solid rgba(245, 243, 238, 0.1);
      font-size: 0.92rem;
    }

    .kairn-menu a:last-child {
      border-bottom: none;
    }

    .kairn-actions {
      grid-area: actions;
      gap: 14px;
    }

    .kairn-hero {
      min-height: 100svh;
    }

    .kairn-hero::before {
      background:
        radial-gradient(circle at 84% 21%, rgba(255,255,255,0.035), transparent 34%),
        linear-gradient(110deg, #090909, #111 100%);
    }

    .kairn-hero::after {
      display: block;
      width: 100%;
      opacity: 0.32;
    }

    .kairn-benefits-grid,
    .kairn-product-grid,
    .kairn-material-list,
    .kairn-about-grid {
      grid-template-columns: 1fr;
    }

    .kairn-bundle {
      grid-template-columns: 1fr;
      text-align: center;
      padding: 28px;
    }

    .kairn-bundle-media {
      width: min(100%, 420px);
      margin-inline: auto;
    }
  }

  @media (max-width: 560px) {
    .kairn-shell {
      width: min(100% - 28px, var(--kairn-max));
    }

    .kairn-nav {
      padding: 15px 14px;
    }

    .kairn-nav.is-scrolled,
    .kairn-nav.is-menu-open {
      padding-block: 12px;
    }

    .kairn-logo {
      width: clamp(108px, 32vw, 132px);
    }

    .kairn-actions {
      gap: 11px;
      font-size: 0.72rem;
    }

    .kairn-icon,
    .kairn-hamburger {
      width: 20px;
      height: 20px;
    }

    .kairn-title {
      font-size: clamp(3.25rem, 15vw, 4.35rem);
      line-height: 0.93;
    }

    .kairn-hero-copy {
      padding: 92px 0 66px;
    }

    .kairn-hero .kairn-shell {
      width: min(100% - 64px, var(--kairn-max));
    }

    .kairn-hero-text {
      max-width: 295px;
      margin: 28px 0 38px;
      font-size: 1rem;
    }

    .kairn-hero .kairn-button {
      width: 204px;
      padding-inline: 20px;
    }

    .kairn-product-body {
      padding-inline: 22px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .kairn-button {
      transition: none;
    }
  }
</style>

<section class="kairn-home">
  <header class="kairn-nav" data-kairn-nav>
    <a class="kairn-logo" href="{{ routes.root_url }}" aria-label="KAIRN">
      <img src="{{ 'kairn-logo.png' | asset_url }}" alt="KAIRN" width="3240" height="472" loading="eager">
    </a>
    <nav class="kairn-menu" id="kairn-mobile-menu" aria-label="Hlavní navigace" data-kairn-menu>
      <a href="{{ collection_link }}">Kolekce</a>
      <a href="#o-nas">O nás</a>
      <a href="#materialy">Materiály</a>
      <a href="/pages/contact">Kontakt</a>
    </nav>
    <div class="kairn-actions">
      <button
        type="button"
        class="kairn-hamburger"
        data-kairn-menu-toggle
        aria-expanded="false"
        aria-controls="kairn-mobile-menu"
      >
        <span data-icon-open aria-hidden="true">{{ 'icon-menu.svg' | inline_asset_content }}</span>
        <span data-icon-close aria-hidden="true">{{ 'icon-close.svg' | inline_asset_content }}</span>
        <span class="visually-hidden">Menu</span>
      </button>
      <span class="kairn-currency">
        {{ localization.country.currency.iso_code | default: 'CZK' }}
        <span class="kairn-caret" aria-hidden="true">{{ 'icon-caret.svg' | inline_asset_content }}</span>
      </span>
      <a class="kairn-icon" href="{{ routes.account_url }}" aria-label="Účet">
        {{ 'icon-account.svg' | inline_asset_content }}
      </a>
      <a class="kairn-icon" href="{{ routes.cart_url }}" aria-label="Košík">
        {{ 'icon-cart.svg' | inline_asset_content }}
        <span class="kairn-cart-bubble" aria-hidden="true">{{ cart.item_count }}</span>
      </a>
    </div>
  </header>

  <div class="kairn-hero">
    <div class="kairn-shell">
      <div class="kairn-hero-copy">
        <span class="kairn-eyebrow">Kolekce 01</span>
        <h1 class="kairn-title">Built quiet.<br>Worn daily.</h1>
        <p class="kairn-hero-text">
          Minimalistické šperky pro muže, kteří budují disciplínu, tělo a byznys. Žádné loga. Žádný hluk. Jen ty a tvůj standard.
        </p>
        <a class="kairn-button" href="{{ collection_link }}">Objevit kolekci <span aria-hidden="true">&rarr;</span></a>
      </div>
    </div>
  </div>

  <div class="kairn-benefits">
    <div class="kairn-shell kairn-benefits-grid">
      <div class="kairn-benefit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 3s7 7 7 12a7 7 0 0 1-14 0c0-5 7-12 7-12Z"/></svg>
        <div><strong>Waterproof</strong><span>Odolné vůči vodě, potu a každodennímu nošení.</span></div>
      </div>
      <div class="kairn-benefit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="m12 3 8 4v5c0 5-3.5 8-8 9-4.5-1-8-4-8-9V7l8-4Z"/><path d="m9 12 2 2 4-5"/></svg>
        <div><strong>Premium materiály</strong><span>Chirurgická ocel 316L. Nerezaví, neztrácí barvu.</span></div>
      </div>
      <div class="kairn-benefit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="m12 2 8 4.5v9L12 20l-8-4.5v-9L12 2Z"/><path d="M12 11 4.5 6.8"/><path d="M12 11v8.5"/><path d="m12 11 7.5-4.2"/></svg>
        <div><strong>Minimalistický design</strong><span>Čisté linie. Nadčasový styl. Pro každou příležitost.</span></div>
      </div>
      <div class="kairn-benefit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M21 12a9 9 0 1 1-3-6.7"/><path d="M21 4v6h-6"/></svg>
        <div><strong>14 dní na vrácení</strong><span>Bez otázek. Bez rizika. 100% spokojenost.</span></div>
      </div>
    </div>
  </div>

  <section class="kairn-products" id="kolekce">
    <div class="kairn-shell">
      <div class="kairn-centered">
        <span class="kairn-section-kicker">Kolekce 01</span>
        <h2 class="kairn-section-title">3 produkty. 1 standard.</h2>
        <div class="kairn-rule"></div>
      </div>

      <div class="kairn-product-grid">
        {% for block in section.blocks %}
          {% if block.type == 'product' %}
            {% liquid
              assign product = block.settings.product
              assign selected_variant = product.selected_or_first_available_variant
              assign title = block.settings.title
              assign price = block.settings.price
              if product != blank
                assign title = product.title
                assign price = selected_variant.price | money
              endif

              assign product_index = forloop.index
              assign product_index_display = product_index
              if product_index < 10
                assign product_index_display = '0' | append: product_index
              endif
            %}
            <article class="kairn-product-card" {{ block.shopify_attributes }}>
              <div class="kairn-product-media"></div>
              <div class="kairn-product-body">
                <span class="kairn-product-num">{{ product_index_display }}</span>
                <h3 class="kairn-product-title">{{ title }}</h3>
                <p class="kairn-product-desc">{{ block.settings.description }}</p>
                <strong class="kairn-price">{{ price }}</strong>
                {% if product != blank %}
                  {% form 'product', product %}
                    <input type="hidden" name="id" value="{{ selected_variant.id }}">
                    <button class="kairn-button kairn-button--dark" type="submit">Přidat do košíku</button>
                  {% endform %}
                {% else %}
                  <a class="kairn-button kairn-button--dark" href="{{ collection_link }}">Přidat do košíku</a>
                {% endif %}
              </div>
            </article>
          {% endif %}
        {% endfor %}
      </div>

      <div class="kairn-bundle">
        <div class="kairn-bundle-media"></div>
        <div class="kairn-bundle-copy">
          <span>Bundle set</span>
          <h3>Řetízek + náramek</h3>
          <p>Kompletní set. Vyladěný do posledního detailu.</p>
          <strong class="kairn-price">1 390 Kč</strong>
        </div>
        <a class="kairn-button kairn-button--dark" href="{{ collection_link }}">Vybrat bundle <span aria-hidden="true">&rarr;</span></a>
      </div>
    </div>
  </section>

  <section class="kairn-materials" id="materialy">
    <div class="kairn-shell">
      <div class="kairn-materials-copy">
        <span class="kairn-section-kicker">Materiály</span>
        <h2 class="kairn-section-title">Kvalita bez kompromisů</h2>
        <p>Používáme pouze chirurgickou ocel 316L. Odolná vůči vodě, potu a poškrábání. Vypadá skvěle. Navždy.</p>
        <div class="kairn-material-list">
          <div class="kairn-benefit">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="m12 3 8 4v5c0 5-3.5 8-8 9-4.5-1-8-4-8-9V7l8-4Z"/><path d="m9 12 2 2 4-5"/></svg>
            <div><strong>Chirurgická ocel 316L</strong><span>Hypoalergenní, bezpečná pro citlivou pokožku.</span></div>
          </div>
          <div class="kairn-benefit">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 3s7 7 7 12a7 7 0 0 1-14 0c0-5 7-12 7-12Z"/></svg>
            <div><strong>Vyrobeno pro každý den</strong><span>Sprcha, trénink, moře. Bez starostí.</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="kairn-about" id="o-nas">
    <div class="kairn-shell kairn-about-grid">
      <div class="kairn-about-media"></div>
      <div>
        <span class="kairn-section-kicker">O KAIRN</span>
        <h2>Disciplína je tvůj znak</h2>
        <p>KAIRN není jen šperk. Je to připomínka toho, kým se stáváš. Každý den. Bez výmluv.</p>
        <a class="kairn-button" href="/pages/about">Více o značce <span aria-hidden="true">&rarr;</span></a>
      </div>
    </div>
  </section>
</section>

<script>
  (() => {
    const initKairnNav = () => {
      const navs = document.querySelectorAll('[data-kairn-nav]');

      if (!navs.length) return;

      const SCROLL_THRESHOLD = 24;

      // Horizon scrolls a wrapping div.page-wrapper on wider/desktop
      // layouts (html/body get overflow-y: hidden there), but on
      // narrow/mobile layouts that wrapper is static and the window
      // itself scrolls instead. Rather than guess which applies,
      // read both and take whichever has actually moved.
      const pageWrapper = document.querySelector('.page-wrapper');

      const getScrollTop = () => {
        const windowTop = window.scrollY || document.documentElement.scrollTop || document.body.scrollTop || 0;
        const wrapperTop = pageWrapper ? pageWrapper.scrollTop : 0;
        return Math.max(windowTop, wrapperTop);
      };

      const updateNav = () => {
        const scrollTop = getScrollTop();
        navs.forEach((nav) => nav.classList.toggle('is-scrolled', scrollTop > SCROLL_THRESHOLD));
      };

      updateNav();
      requestAnimationFrame(updateNav);
      window.addEventListener('scroll', updateNav, { passive: true });
      if (pageWrapper) pageWrapper.addEventListener('scroll', updateNav, { passive: true });
      window.addEventListener('resize', updateNav);
    };

    const initKairnMenuToggle = () => {
      const nav = document.querySelector('[data-kairn-nav]');
      const toggle = document.querySelector('[data-kairn-menu-toggle]');
      const menu = document.querySelector('[data-kairn-menu]');

      if (!nav || !toggle || !menu) return;

      const setOpen = (open) => {
        nav.classList.toggle('is-menu-open', open);
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      };

      toggle.addEventListener('click', () => {
        setOpen(!nav.classList.contains('is-menu-open'));
      });

      menu.addEventListener('click', (event) => {
        if (event.target.closest('a')) setOpen(false);
      });

      document.addEventListener('click', (event) => {
        if (!nav.classList.contains('is-menu-open')) return;
        if (!nav.contains(event.target)) setOpen(false);
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') setOpen(false);
      });

      window.addEventListener('resize', () => {
        if (window.innerWidth > 900) setOpen(false);
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        initKairnNav();
        initKairnMenuToggle();
      });
    } else {
      initKairnNav();
      initKairnMenuToggle();
    }
  })();
</script>

