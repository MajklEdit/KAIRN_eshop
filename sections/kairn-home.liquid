{% liquid
  assign collection_link = section.settings.collection_link | default: routes.all_products_collection_url
%}

<style>
  #header-group {
    display: none;
  }

  .kairn-home {
    --kairn-black: #050505;
    --kairn-ink: #f5f3ee;
    --kairn-muted: rgba(245, 243, 238, 0.68);
    --kairn-line: rgba(245, 243, 238, 0.16);
    --kairn-paper: #f3f1eb;
    --kairn-paper-ink: #111;
    --kairn-max: 1240px;
    background: var(--kairn-black);
    color: var(--kairn-ink);
    font-family: var(--font-body--family), Arial, sans-serif;
    letter-spacing: 0;
  }

  .kairn-home a {
    color: inherit;
    text-decoration: none;
  }

  .kairn-shell {
    width: min(100% - 48px, var(--kairn-max));
    margin-inline: auto;
  }

  .kairn-nav {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 3;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
    padding-block: 34px;
  }

  .kairn-logo {
    font-size: clamp(1.65rem, 3vw, 2.35rem);
    letter-spacing: 0.28em;
    font-weight: 500;
  }

  .kairn-menu {
    display: flex;
    align-items: center;
    gap: clamp(26px, 4vw, 58px);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .kairn-actions {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 18px;
    color: rgba(245, 243, 238, 0.82);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .kairn-icon {
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: currentColor;
  }

  .kairn-hero {
    position: relative;
    min-height: 760px;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
  }

  .kairn-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      radial-gradient(circle at 72% 38%, rgba(255,255,255,0.13), transparent 24%),
      linear-gradient(90deg, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.68) 42%, rgba(0,0,0,0.16) 100%),
      #080808;
  }

  .kairn-hero::after {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(68vw, 980px);
    z-index: -1;
    background:
      linear-gradient(90deg, rgba(0,0,0,0.9), rgba(0,0,0,0.04) 38%),
      linear-gradient(135deg, #0a0a0a, #171717 42%, #050505);
  }

  .kairn-hero-copy {
    max-width: 520px;
    padding-top: 84px;
  }

  .kairn-eyebrow,
  .kairn-section-kicker {
    display: block;
    margin-bottom: 24px;
    color: rgba(245, 243, 238, 0.62);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .kairn-title,
  .kairn-section-title {
    margin: 0;
    font-family: var(--font-heading--family), Impact, sans-serif;
    font-size: clamp(3.8rem, 8vw, 6.7rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: 0.045em;
    text-transform: uppercase;
  }

  .kairn-hero-text {
    max-width: 410px;
    margin: 34px 0 42px;
    color: var(--kairn-muted);
    font-size: 1.04rem;
    line-height: 1.55;
    font-weight: 600;
  }

  .kairn-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    min-height: 54px;
    padding: 0 32px;
    border: 1px solid transparent;
    background: var(--kairn-paper);
    color: var(--kairn-paper-ink);
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .kairn-button:hover {
    transform: translateY(-2px);
    background: #fff;
  }

  .kairn-button--dark {
    background: #000;
    color: #fff;
  }

  .kairn-button--dark:hover {
    background: #161616;
  }

  .kairn-benefits {
    background: rgba(10, 10, 10, 0.98);
    border-top: 1px solid rgba(255,255,255,0.08);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .kairn-benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
    padding-block: 34px;
  }

  .kairn-benefit {
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 16px;
    align-items: start;
  }

  .kairn-benefit svg {
    width: 34px;
    height: 34px;
    stroke-width: 1.5;
    opacity: 0.86;
  }

  .kairn-benefit strong {
    display: block;
    margin-bottom: 8px;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .kairn-benefit span {
    color: var(--kairn-muted);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  .kairn-products {
    background: var(--kairn-paper);
    color: var(--kairn-paper-ink);
    padding: 64px 0 70px;
  }

  .kairn-centered {
    text-align: center;
  }

  .kairn-products .kairn-section-kicker {
    color: rgba(17, 17, 17, 0.48);
    margin-bottom: 14px;
  }

  .kairn-products .kairn-section-title {
    font-size: clamp(2.4rem, 4.6vw, 4.1rem);
  }

  .kairn-rule {
    width: 58px;
    height: 2px;
    margin: 26px auto 42px;
    background: #111;
  }

  .kairn-product-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 28px;
  }

  .kairn-product-card {
    background: #fff;
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  .kairn-product-media,
  .kairn-bundle-media,
  .kairn-about-media {
    background:
      radial-gradient(circle at 60% 35%, rgba(255,255,255,0.12), transparent 24%),
      linear-gradient(135deg, #020202, #151515 48%, #050505);
  }

  .kairn-product-media {
    aspect-ratio: 1 / 0.86;
  }

  .kairn-product-body {
    padding: 32px 28px 30px;
    text-align: center;
  }

  .kairn-product-num {
    display: block;
    margin-bottom: 20px;
    color: rgba(17,17,17,0.55);
    font-size: 0.8rem;
    font-weight: 900;
  }

  .kairn-product-title {
    margin: 0 0 14px;
    font-family: var(--font-heading--family), Impact, sans-serif;
    font-size: 1.5rem;
    line-height: 1.05;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .kairn-product-desc {
    margin: 0 auto 22px;
    max-width: 310px;
    color: rgba(17,17,17,0.68);
    font-size: 0.94rem;
    line-height: 1.45;
    font-weight: 600;
  }

  .kairn-price {
    display: block;
    margin-bottom: 24px;
    font-size: 1.45rem;
    font-weight: 900;
  }

  .kairn-bundle {
    margin-top: 38px;
    display: grid;
    grid-template-columns: minmax(180px, 320px) 1fr auto;
    gap: 34px;
    align-items: center;
    background: #e8e6df;
    padding: 32px 42px;
  }

  .kairn-bundle-media {
    aspect-ratio: 1.8 / 1;
    background-color: #111;
  }

  .kairn-bundle-copy span {
    display: block;
    margin-bottom: 10px;
    color: rgba(17,17,17,0.55);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .kairn-bundle-copy h3 {
    margin: 0 0 10px;
    font-family: var(--font-heading--family), Impact, sans-serif;
    font-size: clamp(2rem, 4vw, 3.1rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .kairn-bundle-copy p {
    margin: 0 0 20px;
    color: rgba(17,17,17,0.68);
    font-weight: 600;
  }

  .kairn-materials {
    min-height: 680px;
    display: grid;
    align-items: center;
    background:
      linear-gradient(90deg, rgba(0,0,0,0.94), rgba(0,0,0,0.72) 42%, rgba(0,0,0,0.18)),
      linear-gradient(135deg, #050505, #171717 45%, #050505);
    color: var(--kairn-ink);
    padding: 76px 0;
  }

  .kairn-materials-copy {
    max-width: 480px;
  }

  .kairn-materials .kairn-section-title {
    font-size: clamp(2.7rem, 5vw, 4.6rem);
  }

  .kairn-materials p {
    color: var(--kairn-muted);
    line-height: 1.58;
    font-weight: 600;
  }

  .kairn-material-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 26px;
    margin-top: 44px;
  }

  .kairn-about {
    background: #080808;
    color: var(--kairn-ink);
    padding: 0 0 72px;
  }

  .kairn-about-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 70px;
    align-items: center;
  }

  .kairn-about-media {
    min-height: 420px;
  }

  .kairn-about h2 {
    margin: 0 0 24px;
    font-family: var(--font-heading--family), Impact, sans-serif;
    font-size: clamp(2.6rem, 5vw, 4.8rem);
    line-height: 1;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .kairn-about p {
    max-width: 400px;
    color: var(--kairn-muted);
    line-height: 1.55;
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .kairn-shell {
      width: min(100% - 32px, var(--kairn-max));
    }

    .kairn-nav {
      grid-template-columns: 1fr auto;
      padding-block: 24px;
    }

    .kairn-menu {
      display: none;
    }

    .kairn-actions {
      gap: 12px;
    }

    .kairn-hero {
      min-height: 680px;
    }

    .kairn-benefits-grid,
    .kairn-product-grid,
    .kairn-material-list,
    .kairn-about-grid {
      grid-template-columns: 1fr;
    }

    .kairn-bundle {
      grid-template-columns: 1fr;
      text-align: center;
      padding: 28px;
    }

    .kairn-bundle-media {
      width: min(100%, 420px);
      margin-inline: auto;
    }
  }

  @media (max-width: 560px) {
    .kairn-title {
      font-size: clamp(3.1rem, 15vw, 4.5rem);
    }

    .kairn-hero-copy {
      padding-top: 110px;
    }

    .kairn-product-body {
      padding-inline: 22px;
    }
  }
</style>

<section class="kairn-home">
  <div class="kairn-hero">
    <header class="kairn-nav kairn-shell">
      <a class="kairn-logo" href="{{ routes.root_url }}" aria-label="KAIRN">KAIRN</a>
      <nav class="kairn-menu" aria-label="Main navigation">
        <a href="{{ collection_link }}">Kolekce</a>
        <a href="#o-nas">O nas</a>
        <a href="#materialy">Materialy</a>
        <a href="/pages/contact">Kontakt</a>
      </nav>
      <div class="kairn-actions">
        <span>{{ localization.country.currency.iso_code }}</span>
        <a class="kairn-icon" href="{{ routes.account_url }}" aria-label="Account">
          {{ 'icon-account.svg' | inline_asset_content }}
        </a>
        <a class="kairn-icon" href="{{ routes.cart_url }}" aria-label="Cart">
          {{ 'icon-cart.svg' | inline_asset_content }}
        </a>
      </div>
    </header>

    <div class="kairn-shell">
      <div class="kairn-hero-copy">
        <span class="kairn-eyebrow">Kolekce 01</span>
        <h1 class="kairn-title">Built quiet.<br>Worn daily.</h1>
        <p class="kairn-hero-text">
          Minimalisticke sperky pro muze, kteri buduji disciplinu, telo a byznys. Zadny hluk. Jen ty a tvuj standard.
        </p>
        <a class="kairn-button" href="{{ collection_link }}">Objevit kolekci <span aria-hidden="true">&rarr;</span></a>
      </div>
    </div>
  </div>

  <div class="kairn-benefits">
    <div class="kairn-shell kairn-benefits-grid">
      <div class="kairn-benefit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 3s7 7 7 12a7 7 0 0 1-14 0c0-5 7-12 7-12Z"/></svg>
        <div><strong>Waterproof</strong><span>Odolne vuci vode, potu a kazdodennimu noseni.</span></div>
      </div>
      <div class="kairn-benefit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="m12 3 8 4v5c0 5-3.5 8-8 9-4.5-1-8-4-8-9V7l8-4Z"/><path d="m9 12 2 2 4-5"/></svg>
        <div><strong>Premium materialy</strong><span>Chirurgicka ocel 316L. Nerezavi, neztraci barvu.</span></div>
      </div>
      <div class="kairn-benefit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="m12 2 8 4.5v9L12 20l-8-4.5v-9L12 2Z"/><path d="M12 11 4.5 6.8"/><path d="M12 11v8.5"/><path d="m12 11 7.5-4.2"/></svg>
        <div><strong>Minimalisticky design</strong><span>Ciste linie. Nadcasovy styl pro kazdou prilezitost.</span></div>
      </div>
      <div class="kairn-benefit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M21 12a9 9 0 1 1-3-6.7"/><path d="M21 4v6h-6"/></svg>
        <div><strong>14 dni na vraceni</strong><span>Bez otazek. Bez rizika. 100% spokojenost.</span></div>
      </div>
    </div>
  </div>

  <section class="kairn-products" id="kolekce">
    <div class="kairn-shell">
      <div class="kairn-centered">
        <span class="kairn-section-kicker">Kolekce 01</span>
        <h2 class="kairn-section-title">3 produkty. 1 standard.</h2>
        <div class="kairn-rule"></div>
      </div>

      <div class="kairn-product-grid">
        {% for block in section.blocks %}
          {% if block.type == 'product' %}
            {% liquid
              assign product = block.settings.product
              assign selected_variant = product.selected_or_first_available_variant
              assign title = block.settings.title
              assign price = block.settings.price
              if product != blank
                assign title = product.title
                assign price = selected_variant.price | money
              endif
            %}
            <article class="kairn-product-card" {{ block.shopify_attributes }}>
              <div class="kairn-product-media"></div>
              <div class="kairn-product-body">
                <span class="kairn-product-num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
                <h3 class="kairn-product-title">{{ title }}</h3>
                <p class="kairn-product-desc">{{ block.settings.description }}</p>
                <strong class="kairn-price">{{ price }}</strong>
                {% if product != blank %}
                  {% form 'product', product %}
                    <input type="hidden" name="id" value="{{ selected_variant.id }}">
                    <button class="kairn-button kairn-button--dark" type="submit">Pridat do kosiku</button>
                  {% endform %}
                {% else %}
                  <a class="kairn-button kairn-button--dark" href="{{ collection_link }}">Pridat do kosiku</a>
                {% endif %}
              </div>
            </article>
          {% endif %}
        {% endfor %}
      </div>

      <div class="kairn-bundle">
        <div class="kairn-bundle-media"></div>
        <div class="kairn-bundle-copy">
          <span>Bundle set</span>
          <h3>Retizek + naramek</h3>
          <p>Kompletni set. Vyladeny do posledniho detailu.</p>
          <strong class="kairn-price">1 390 Kc</strong>
        </div>
        <a class="kairn-button kairn-button--dark" href="{{ collection_link }}">Vybrat bundle <span aria-hidden="true">&rarr;</span></a>
      </div>
    </div>
  </section>

  <section class="kairn-materials" id="materialy">
    <div class="kairn-shell">
      <div class="kairn-materials-copy">
        <span class="kairn-section-kicker">Materialy</span>
        <h2 class="kairn-section-title">Kvalita bez kompromisu</h2>
        <p>Pouzivame pouze chirurgickou ocel 316L. Odolna vuci vode, potu a poskrabani. Vypada skvele. Navzdy.</p>
        <div class="kairn-material-list">
          <div class="kairn-benefit">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="m12 3 8 4v5c0 5-3.5 8-8 9-4.5-1-8-4-8-9V7l8-4Z"/><path d="m9 12 2 2 4-5"/></svg>
            <div><strong>Chirurgicka ocel 316L</strong><span>Hypoalergenni, bezpecna pro citlivou pokozku.</span></div>
          </div>
          <div class="kairn-benefit">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 3s7 7 7 12a7 7 0 0 1-14 0c0-5 7-12 7-12Z"/></svg>
            <div><strong>Vyrobeno pro kazdy den</strong><span>Sprcha, trenink, more. Bez starosti.</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="kairn-about" id="o-nas">
    <div class="kairn-shell kairn-about-grid">
      <div class="kairn-about-media"></div>
      <div>
        <span class="kairn-section-kicker">O KAIRN</span>
        <h2>Disciplina je tvuj znak</h2>
        <p>KAIRN neni jen sperk. Je to pripominka toho, kym se stavas. Kazdy den. Bez vymluv.</p>
        <a class="kairn-button" href="/pages/about">Vice o znacce <span aria-hidden="true">&rarr;</span></a>
      </div>
    </div>
  </section>
</section>

{% schema %}
{
  "name": "KAIRN homepage",
  "settings": [
    {
      "type": "url",
      "id": "collection_link",
      "label": "Collection link"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Shopify product"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Fallback title",
          "default": "Snake chain necklace"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Kus discipline pro kazdy den. Cisty, minimalisticky standard."
        },
        {
          "type": "text",
          "id": "price",
          "label": "Fallback price",
          "default": "890 Kc"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KAIRN homepage",
      "blocks": [
        {
          "type": "product",
          "settings": {
            "title": "Snake chain necklace",
            "description": "Kulaty retizek 2mm z chirurgicke oceli 316L. Cisty. Nadcasovy. Pro kazdy den.",
            "price": "890 Kc"
          }
        },
        {
          "type": "product",
          "settings": {
            "title": "Double-layer bracelet",
            "description": "Dvouvrstvy naramek s jemnym profilem. Minimalismus, ktery vynikne.",
            "price": "790 Kc"
          }
        },
        {
          "type": "product",
          "settings": {
            "title": "Knotted bracelet",
            "description": "Uzlovy motiv jako symbol zavazku. Lehky, odolny, unisex.",
            "price": "590 Kc"
          }
        }
      ]
    }
  ]
}
{% endschema %}
